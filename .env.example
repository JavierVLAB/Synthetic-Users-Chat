# ─────────────────────────────────────────────────────────────────────────────
# Variables de entorno — Sistema de usuarios sintéticos Moeve
#
# 1. Copia este archivo:  cp .env.example .env
# 2. Rellena los valores  (nunca subas .env al repositorio)
# ─────────────────────────────────────────────────────────────────────────────


# ── Motor LLM ─────────────────────────────────────────────────────────────────

# Proveedor LLM activo. Valores posibles: openai | anthropic | ollama
LLM_PROVIDER=openai

# Número máximo de mensajes del historial que se envían al LLM como contexto.
# Los más antiguos se descartan (ventana deslizante). Default: 20.
MAX_CONTEXT_MESSAGES=20


# ── Credenciales de proveedores LLM ───────────────────────────────────────────

# API key de OpenAI (necesaria si LLM_PROVIDER=openai)
# Obtener en: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# API key de Anthropic (necesaria si LLM_PROVIDER=anthropic)
# Obtener en: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# URL base del servidor Ollama (necesaria si LLM_PROVIDER=ollama)
# Por defecto apunta a Ollama en local
OLLAMA_BASE_URL=http://localhost:11434

# Modelo de Ollama a usar (necesario si LLM_PROVIDER=ollama)
OLLAMA_MODEL=llama3


# ── Seguridad ─────────────────────────────────────────────────────────────────

# Token secreto para endpoints de administración (gestión de perfiles y briefs).
# Enviar en el header: X-Admin-Token: <valor>
# Genera uno seguro con: openssl rand -hex 32
ADMIN_TOKEN=

# Orígenes permitidos para CORS, separados por comas.
# En desarrollo: http://localhost:3000
# En producción: el dominio real de la aplicación
ALLOWED_ORIGINS=http://localhost:3000


# ── Frontend (Next.js) ────────────────────────────────────────────────────────

# URL del backend accesible desde el navegador.
# En desarrollo local: http://localhost:8000
# En Docker Compose: http://localhost:8000 (el puerto expuesto del backend)
NEXT_PUBLIC_API_URL=http://localhost:8000
